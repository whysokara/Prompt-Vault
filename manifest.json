{
  "manifest_version": 3,
  "name": "Prompt Vault",
  "version": "1.0.0",
  "description": "Save prompts you find on the web. Right-click any selected text and send it to Prompt Vault.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Prompt Vault",
    "default_icon": "icons/icon.svg"
  }
}
